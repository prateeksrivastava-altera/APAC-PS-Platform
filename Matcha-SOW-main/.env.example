# Server Configuration
PORT=3000
NODE_ENV=production

# Session Secret (change this in production)
SESSION_SECRET=your-secret-key-change-in-production

# Matcha API Configuration
MATCHA_API_KEY=your_matcha_api_key_here
WORKSPACE_ID=2010
MISSION_ID=7618
BASE_URL=https://matcha.harriscomputer.com/rest/api/v1
FOLDER_ID=10917

# Document Intelligence - Extraction Mission (Feature: Extract from Documents in SOW Generator)
# Create a dedicated Matcha mission for document extraction and set its ID and folder ID here
EXTRACTION_MISSION_ID=34186
EXTRACTION_FOLDER_ID=your_extraction_folder_id_here

# Azure AD SSO Configuration (Optional - enables "Sign in with Microsoft" button)
# Follow Azure App Registration steps in the plan to obtain these values.
# If any of these are missing, the SSO button will be hidden and local auth still works.
# AZURE_CLIENT_ID=your_application_client_id
# AZURE_CLIENT_SECRET=your_client_secret_value
# AZURE_TENANT_ID=your_directory_tenant_id
# AZURE_REDIRECT_URI=http://localhost:3000/auth/azure/callback
# For production, AZURE_REDIRECT_URI must match the Redirect URI in your App Registration exactly.
