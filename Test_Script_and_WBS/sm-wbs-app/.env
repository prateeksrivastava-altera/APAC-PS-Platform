# --- Server ---
# PORT is set by the APAC shell launcher (random ephemeral 127.0.0.1 port).
# Leave PORT unset/commented to honour the launcher; set it explicitly only
# when running standalone for debugging.
# PORT=5000

# dev | prod  — controls which DB credential set is used.
MODE=dev

# --- PostgreSQL (dev) ---
# This app owns the apac_wbs database and connects as its own least-privilege
# role apac_wbs_app (provisioned via db/provision_apac_wbs.sql).
# Host=localhost;Port=5432;Database=apac_wbs;Username=apac_wbs_app;Password=...
WBS_DB_HOST_DEV=localhost
WBS_DB_PORT_DEV=5432
WBS_DB_NAME_DEV=apac_wbs
WBS_DB_USER_DEV=apac_wbs_app
WBS_DB_PASSWORD_DEV=apac_wbs_local_pw

# --- PostgreSQL (prod) ---
# Fill in at hosting time.
WBS_DB_HOST_PROD=
WBS_DB_PORT_PROD=5432
WBS_DB_NAME_PROD=apac_wbs
WBS_DB_USER_PROD=apac_wbs_app
WBS_DB_PASSWORD_PROD=
# When prod is behind a managed Postgres (RDS, Cloud SQL, Heroku, etc) you
# likely want WBS_DB_SSL=require. Leave blank for local.
WBS_DB_SSL=

# Per-app connection pool size (default 10). Keep bounded so the shared
# Postgres server's max_connections isn't exhausted as more apps are added.
WBS_DB_POOL_MAX=10

# --- Admin bootstrap ---
# Comma-separated email(s) force-promoted to admin on every startup. The dev
# identity's email is <username>@local.
WBS_BOOTSTRAP_ADMIN=SMENON@local

# --- Matcha LLM (AI Project Analyst) ---
MATCHA_API_KEY=227c155241a54ee286b537d10645295e
WORKSPACE_ID=11797
BASE_URL=https://matcha.harriscomputer.com/rest/api/v1

# Pipeline Mission IDs (in execution order)
MISSION_ID_WBS=40847

MATCHA_TIMEOUT_SECONDS=240
